# Frontend feature flags
# Keep AI disabled by default for handoff/offline builds.
VITE_ENABLE_AI=false

# Optional PHP backend endpoint for narrative generation.
# Leave blank when the API is hosted under the same base path.
VITE_API_URL=

# Do not put OpenAI keys in VITE_* variables.
# Server-side keys belong in the PHP backend environment, for example api/.env.local on the server.
